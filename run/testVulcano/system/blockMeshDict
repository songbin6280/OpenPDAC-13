        addVertex(vector($atm_x_pos, 0, z_level),
                  prefix + " Far E0"); // New Idx 12
        addVertex(vector($atm_x_pos, icylExt_y, z_level),
                  prefix + " Far E1"); // New Idx 13
        addVertex(vector($atm_x_pos, $atm_y_pos, z_level),
                  prefix + " Far NEc"); // New Idx 14
        addVertex(vector(icylExt_x, $atm_y_pos, z_level),
                  prefix + " Far N1"); // New Idx 15

        z_level = $atm_top_z * layer_fraction[layer];

        r_cr_top = $r_crater_top * pow($exp_fact, layer);

        Info << "top level " << z_level << endl;

        label listIdxTop =
            layer; // Index in lists for vertices at the TOP of this layer

        Info << "Generating vertices for top of Layer " << layer
             << " (z=" << z_level << ", List Index " << listIdxTop << ")"
             << endl;

        // --- Generate TOP vertices for Layer 'layer' ---
        L_center_Start[listIdxTop] = addVertex(
            vector(dx, dy, z_level), "L" + Foam::name(layer) + " Top Ctr");
        makeRing(L_oct_Start[listIdxTop],
                 0.5 * r_cr_top,
                 $coeff * cos(radAngle) * 0.5 * r_cr_top,
                 z_level,
                 dx,
                 dy,
                 "L" + Foam::name(layer) + " Top",
                 "Oct");
                 
                 
        makeRing(L_inr_Start[listIdxTop],
                 r_cr_top,
                 r_cr_top * cos(radAngle),
                 z_level,
                 dx,
                 dy,
                 "L" + Foam::name(layer) + " Top",
                 "Inr");
                                                  
        L_inrDup_Start[listIdxTop] =
            vertexCount; // Duplicates for mergePatchPairs interface at base of
                         // L2
        for (label k = 0; k < 8; ++k)
            addVertex(points[L_inr_Start[listIdxTop] + k],
                      "L" + Foam::name(layer) + " TopInrDup");


        // 1. Calculate scaling parameters for this layer
        // ------------------------------------------------------------------
        // Note: r_cr_top is already defined in your code (crater radius at this layer)

        scalar scale_factor = pow(2.0, layer); 
        scalar d_start_curr = actual_crater_top_size * scale_factor; // Target cell size at the crater rim

        // ------------------------------------------------------------------
        // 2. Calculate outer cell counts (N_outer) scaled for this layer
        //    (nx_pos_out_mult etc. are the cell counts at the base layer)
        //    The count halves as the layer index increases (cells get larger)
        // ------------------------------------------------------------------
        int div_factor = pow(2, layer-1); 
        
        label N_xp = Foam::max(1, (int)round(nx_pos_out_mult / (double)div_factor));
        label N_xn = Foam::max(1, (int)round(nx_neg_out_mult / (double)div_factor));
        label N_yp = Foam::max(1, (int)round(ny_pos_out_mult / (double)div_factor));
        label N_yn = Foam::max(1, (int)round(ny_neg_out_mult / (double)div_factor));

        Info << "N_xp " << N_xp  << " N_yp " << N_yp  << "N_xn " << N_xn  << "N_yn " << N_yn << endl;

        // ------------------------------------------------------------------
        // 3. Solve ring parameters for the 4 cardinal directions (Asymmetry)
        //    (Uses r_cr_top as the inner radius)
        // ------------------------------------------------------------------
        RingParams p_xp = solveRingParameters(r_cr_top, d_start_curr, n_rad_gr_interface, mag($atm_x_pos), N_xp);
        RingParams p_xn = solveRingParameters(r_cr_top, d_start_curr, n_rad_gr_interface, mag($atm_x_neg), N_xn);
        RingParams p_yp = solveRingParameters(r_cr_top, d_start_curr, n_rad_gr_interface, mag($atm_y_pos), N_yp);
        RingParams p_yn = solveRingParameters(r_cr_top, d_start_curr, n_rad_gr_interface, mag($atm_y_neg), N_yn);

        // ------------------------------------------------------------------
        // 4. Select the Minimum Radius (Conservative Strategy)
        //    This defines your new r_icyl to ensure the ring fits within
        //    the domain boundaries in all directions.
        // ------------------------------------------------------------------
        r_icyl = Foam::min(Foam::min(p_xp.R_icyl, p_xn.R_icyl), Foam::min(p_yp.R_icyl, p_yn.R_icyl));

        // ------------------------------------------------------------------
        // 5. Find and Store the Grading corresponding to the chosen radius
        // ------------------------------------------------------------------
        scalar calculated_grading = 1.0;
        
        if      (Foam::mag(r_icyl - p_xp.R_icyl) < 1e-4) calculated_grading = p_xp.grading;
        else if (Foam::mag(r_icyl - p_xn.R_icyl) < 1e-4) calculated_grading = p_xn.grading;
        else if (Foam::mag(r_icyl - p_yp.R_icyl) < 1e-4) calculated_grading = p_yp.grading;
        else                                             calculated_grading = p_yn.grading;

        // IMPORTANT: Store this grading in the list to use it later in the 'blocks' section
        storedGradings[layer] = calculated_grading;
        storedRadiusCyl[layer] = r_icyl;

        Info << "Layer " << layer << " Optimization: r_cr_top=" << r_cr_top 
             << " -> r_icyl=" << r_icyl << " (Grading=" << calculated_grading << ")" << endl;



        makeRing(L_icyl_Start[listIdxTop],
                 r_icyl,
                 r_icyl * cos(radAngle),
                 z_level,
                 dx,
                 dy,
