            os << "    hex ("
               // Base Face (z=crater_base_z) - CCW Winding: Ctr, V0, V1, V2
               << L_crBase_center << " " // v0 (Center)
               << vIdx(L_crBase_oct_Start, oct_idx0) << " " // v1
