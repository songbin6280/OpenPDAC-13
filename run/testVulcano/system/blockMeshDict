               << ") simpleGrading (1 1 " << grading
               << ") // Conduit Ctr Quadrant " << q << endl;
        }

        // Conduit Outer Blocks (8 blocks)
        for (int i = 0; i < 8; ++i)
        {
            int i_plus_1 = (i + 1) % 8;

            os << "    hex ("
               // Base Face (z=conduit_base_z) - CCW Winding
               << vIdx(L_condBase_oct_Start, i) << " "
