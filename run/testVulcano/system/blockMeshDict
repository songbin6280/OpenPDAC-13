        addVertex(vector(0, $atm_y_neg, z_level),
                  prefix + " Far S0"); // New Idx 8
        addVertex(vector(icylExt_x, $atm_y_neg, z_level),
                  prefix + " Far S1"); // New Idx 9
        addVertex(vector($atm_x_pos, $atm_y_neg, z_level),
