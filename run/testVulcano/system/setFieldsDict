FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultValues
{
    alpha.gas 0.9999999999;
    alpha.particles 0.0000000001;
    air.gas 0.99;
    H2O.gas 0.01;
    T.gas 300.0;
    T.particles 300.0;
}

zones
{
    crater
    {
        type        lookup;
        name        crater;
        zoneType    cell;
        
        values
	{
	    alpha.gas 0.6;
            alpha.particles 0.4; 
            air.gas 0.000001;
            H2O.gas 0.999999;
            p 5000000;
            T.gas 523.0;
            T.particles 523.0;
        };
    }
}


